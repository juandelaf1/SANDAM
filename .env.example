# SANDAM - Environment Variables

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sandam

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=*

# Optional: API Keys for external services
# ACA_API_URL=https://aplicacions.aca.gencat.cat/platges/AppJava/api/front/es
# AEMET_API_KEY=your_aemet_key